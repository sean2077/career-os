[
  {
    "id": "private-key",
    "regex": "-----BEGIN (?:RSA |EC |OPENSSH )?PRIVATE KEY-----"
  },
  {
    "id": "aws-access-key",
    "regex": "AKIA[0-9A-Z]{16}"
  },
  {
    "id": "github-token",
    "regex": "github_pat_[A-Za-z0-9_]{20,}"
  },
  {
    "id": "assigned-secret",
    "regex": "(?i:(?:api[_-]?key|secret[_-]?key)\\s*[:=]\\s*[\\\"']?[A-Za-z0-9_-]{16,})"
  }
]
