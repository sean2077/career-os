{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-os.dev/schemas/skills-lock.schema.json",
  "title": "Career OS Skill Lock",
  "type": "object",
  "required": ["schema_version", "skills"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "source_repository", "revision", "source_path", "tree_sha256", "license", "attribution"],
        "properties": {
          "name": {"type": "string"},
          "source_repository": {"type": "string", "format": "uri"},
          "revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "source_path": {"type": "string"},
          "tree_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "license": {"type": "string"},
          "attribution": {"type": "string"}
        }
      }
    }
  }
}
