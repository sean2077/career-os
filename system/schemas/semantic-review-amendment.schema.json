{
  "$defs": {
    "SemanticAmendmentTarget": {
      "additionalProperties": false,
      "description": "One current file that restores, validates, or documents corrected semantics.",
      "properties": {
        "scope": {
          "enum": [
            "public-framework",
            "personal-instance"
          ],
          "title": "Scope",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "target_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Target Sha256",
          "type": "string"
        },
        "relation": {
          "enum": [
            "restored-by",
            "validated-by",
            "documented-by"
          ],
          "title": "Relation",
          "type": "string"
        }
      },
      "required": [
        "scope",
        "path",
        "target_sha256",
        "relation"
      ],
      "title": "SemanticAmendmentTarget",
      "type": "object"
    },
    "SemanticReviewAmendmentEntry": {
      "additionalProperties": false,
      "description": "Correct one source mapping without rewriting the historical review.",
      "properties": {
        "source_path": {
          "title": "Source Path",
          "type": "string"
        },
        "source_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Source Sha256",
          "type": "string"
        },
        "prior_disposition": {
          "enum": [
            "migrate-exact",
            "migrate-transform",
            "replace-by-public",
            "retain-archive-only",
            "upstream-gap",
            "retire"
          ],
          "title": "Prior Disposition",
          "type": "string"
        },
        "corrected_targets": {
          "items": {
            "$ref": "#/$defs/SemanticAmendmentTarget"
          },
          "minItems": 1,
          "title": "Corrected Targets",
          "type": "array"
        },
        "resolution": {
          "minLength": 1,
          "title": "Resolution",
          "type": "string"
        }
      },
      "required": [
        "source_path",
        "source_sha256",
        "prior_disposition",
        "corrected_targets",
        "resolution"
      ],
      "title": "SemanticReviewAmendmentEntry",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Append-only correction for material mappings in an immutable review.",
  "properties": {
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "control_type": {
      "const": "semantic-review-amendment",
      "default": "semantic-review-amendment",
      "title": "Control Type",
      "type": "string"
    },
    "id": {
      "format": "uuid4",
      "title": "Id",
      "type": "string"
    },
    "issue_id": {
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "title": "Issue Id",
      "type": "string"
    },
    "review_path": {
      "title": "Review Path",
      "type": "string"
    },
    "review_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Review Sha256",
      "type": "string"
    },
    "completion_path": {
      "title": "Completion Path",
      "type": "string"
    },
    "completion_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Completion Sha256",
      "type": "string"
    },
    "source_repository": {
      "minLength": 1,
      "title": "Source Repository",
      "type": "string"
    },
    "source_commit": {
      "pattern": "^[a-f0-9]{40}$",
      "title": "Source Commit",
      "type": "string"
    },
    "status": {
      "const": "complete",
      "title": "Status",
      "type": "string"
    },
    "reason": {
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/SemanticReviewAmendmentEntry"
      },
      "minItems": 1,
      "title": "Entries",
      "type": "array"
    },
    "residual_gaps": {
      "items": {
        "type": "string"
      },
      "maxItems": 0,
      "title": "Residual Gaps",
      "type": "array"
    },
    "corrected_at": {
      "format": "date-time",
      "title": "Corrected At",
      "type": "string"
    }
  },
  "required": [
    "id",
    "issue_id",
    "review_path",
    "review_sha256",
    "completion_path",
    "completion_sha256",
    "source_repository",
    "source_commit",
    "status",
    "reason",
    "entries",
    "residual_gaps",
    "corrected_at"
  ],
  "title": "Career OS Semantic Review Amendment",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-os.dev/schemas/semantic-review-amendment.schema.json"
}
