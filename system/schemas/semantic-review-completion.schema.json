{
  "$defs": {
    "SemanticDownstreamSyncEvidence": {
      "additionalProperties": false,
      "properties": {
        "source_tag": {
          "minLength": 1,
          "title": "Source Tag",
          "type": "string"
        },
        "tag_object": {
          "pattern": "^[a-f0-9]{40}$",
          "title": "Tag Object",
          "type": "string"
        },
        "source_commit": {
          "pattern": "^[a-f0-9]{40}$",
          "title": "Source Commit",
          "type": "string"
        },
        "target_branch": {
          "minLength": 1,
          "title": "Target Branch",
          "type": "string"
        },
        "target_head": {
          "pattern": "^[a-f0-9]{40}$",
          "title": "Target Head",
          "type": "string"
        },
        "desired_tree": {
          "pattern": "^[a-f0-9]{40}$",
          "title": "Desired Tree",
          "type": "string"
        },
        "plan_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Plan Sha256",
          "type": "string"
        },
        "patch_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Patch Sha256",
          "type": "string"
        },
        "result_path": {
          "title": "Result Path",
          "type": "string"
        },
        "result_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Result Sha256",
          "type": "string"
        },
        "applied_at": {
          "format": "date-time",
          "title": "Applied At",
          "type": "string"
        },
        "validated_at": {
          "format": "date-time",
          "title": "Validated At",
          "type": "string"
        }
      },
      "required": [
        "source_tag",
        "tag_object",
        "source_commit",
        "target_branch",
        "target_head",
        "desired_tree",
        "plan_sha256",
        "patch_sha256",
        "result_path",
        "result_sha256",
        "applied_at",
        "validated_at"
      ],
      "title": "SemanticDownstreamSyncEvidence",
      "type": "object"
    },
    "SemanticGap": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "title": "Id",
          "type": "string"
        },
        "material": {
          "title": "Material",
          "type": "boolean"
        },
        "status": {
          "enum": [
            "open",
            "closed"
          ],
          "title": "Status",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "resolution": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolution"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/SemanticReviewEvidence"
          },
          "title": "Evidence",
          "type": "array"
        }
      },
      "required": [
        "id",
        "material",
        "status",
        "description"
      ],
      "title": "SemanticGap",
      "type": "object"
    },
    "SemanticReviewEvidence": {
      "additionalProperties": false,
      "properties": {
        "scope": {
          "enum": [
            "public-framework",
            "personal-instance"
          ],
          "title": "Scope",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "anchor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Anchor"
        },
        "kind": {
          "enum": [
            "target",
            "outcome-test",
            "schema",
            "validator",
            "scenario",
            "archive",
            "retirement"
          ],
          "title": "Kind",
          "type": "string"
        },
        "assertion": {
          "minLength": 1,
          "title": "Assertion",
          "type": "string"
        }
      },
      "required": [
        "scope",
        "path",
        "kind",
        "assertion"
      ],
      "title": "SemanticReviewEvidence",
      "type": "object"
    },
    "SemanticReviewRound": {
      "additionalProperties": false,
      "properties": {
        "lens": {
          "enum": [
            "source-to-target",
            "target-to-source-adversarial"
          ],
          "title": "Lens",
          "type": "string"
        },
        "report_path": {
          "title": "Report Path",
          "type": "string"
        },
        "report_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Report Sha256",
          "type": "string"
        },
        "reviewed_items": {
          "minimum": 1,
          "title": "Reviewed Items",
          "type": "integer"
        },
        "new_material_gaps": {
          "const": 0,
          "default": 0,
          "title": "New Material Gaps",
          "type": "integer"
        },
        "reviewed_at": {
          "format": "date-time",
          "title": "Reviewed At",
          "type": "string"
        }
      },
      "required": [
        "lens",
        "report_path",
        "report_sha256",
        "reviewed_items",
        "reviewed_at"
      ],
      "title": "SemanticReviewRound",
      "type": "object"
    },
    "SemanticValidationRun": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "title": "Id",
          "type": "string"
        },
        "scope": {
          "enum": [
            "public-framework",
            "personal-instance",
            "host"
          ],
          "title": "Scope",
          "type": "string"
        },
        "command": {
          "minLength": 1,
          "title": "Command",
          "type": "string"
        },
        "status": {
          "const": "passed",
          "title": "Status",
          "type": "string"
        },
        "result_path": {
          "title": "Result Path",
          "type": "string"
        },
        "result_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Result Sha256",
          "type": "string"
        },
        "verified_at": {
          "format": "date-time",
          "title": "Verified At",
          "type": "string"
        }
      },
      "required": [
        "id",
        "scope",
        "command",
        "status",
        "result_path",
        "result_sha256",
        "verified_at"
      ],
      "title": "SemanticValidationRun",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 2,
      "default": 2,
      "title": "Schema Version",
      "type": "integer"
    },
    "control_type": {
      "const": "semantic-review-completion",
      "default": "semantic-review-completion",
      "title": "Control Type",
      "type": "string"
    },
    "development_topology": {
      "enum": [
        "integrated-workbench",
        "split-downstream"
      ],
      "title": "Development Topology",
      "type": "string"
    },
    "status": {
      "enum": [
        "local-candidate-complete",
        "complete"
      ],
      "title": "Status",
      "type": "string"
    },
    "source_repository": {
      "minLength": 1,
      "title": "Source Repository",
      "type": "string"
    },
    "source_commit": {
      "pattern": "^[a-f0-9]{40}$",
      "title": "Source Commit",
      "type": "string"
    },
    "inventory_path": {
      "title": "Inventory Path",
      "type": "string"
    },
    "inventory_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Inventory Sha256",
      "type": "string"
    },
    "review_path": {
      "title": "Review Path",
      "type": "string"
    },
    "review_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Review Sha256",
      "type": "string"
    },
    "framework_target_commit": {
      "pattern": "^[a-f0-9]{40}$",
      "title": "Framework Target Commit",
      "type": "string"
    },
    "personal_target_commit": {
      "pattern": "^[a-f0-9]{40}$",
      "title": "Personal Target Commit",
      "type": "string"
    },
    "target_tree_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Target Tree Sha256",
      "type": "string"
    },
    "validation_runs": {
      "items": {
        "$ref": "#/$defs/SemanticValidationRun"
      },
      "minItems": 1,
      "title": "Validation Runs",
      "type": "array"
    },
    "review_rounds": {
      "items": {
        "$ref": "#/$defs/SemanticReviewRound"
      },
      "minItems": 2,
      "title": "Review Rounds",
      "type": "array"
    },
    "downstream_sync": {
      "anyOf": [
        {
          "$ref": "#/$defs/SemanticDownstreamSyncEvidence"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "residual_gaps": {
      "items": {
        "$ref": "#/$defs/SemanticGap"
      },
      "title": "Residual Gaps",
      "type": "array"
    },
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    }
  },
  "required": [
    "development_topology",
    "status",
    "source_repository",
    "source_commit",
    "inventory_path",
    "inventory_sha256",
    "review_path",
    "review_sha256",
    "framework_target_commit",
    "personal_target_commit",
    "target_tree_sha256",
    "validation_runs",
    "review_rounds",
    "completed_at"
  ],
  "title": "Career OS Semantic Review Completion",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-os.dev/schemas/semantic-review-completion.schema.json"
}
