{
  "$defs": {
    "LegacyInventoryRule": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "title": "Id",
          "type": "string"
        },
        "pattern": {
          "title": "Pattern",
          "type": "string"
        },
        "asset_type": {
          "enum": [
            "record",
            "attachment",
            "resume",
            "view",
            "skill",
            "tool",
            "documentation",
            "other"
          ],
          "title": "Asset Type",
          "type": "string"
        },
        "disposition": {
          "enum": [
            "migrate-exact",
            "migrate-transform",
            "replace-by-public",
            "retain-archive-only",
            "upstream-gap",
            "retire"
          ],
          "title": "Disposition",
          "type": "string"
        },
        "replacement": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Replacement"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "required": [
        "id",
        "pattern",
        "asset_type",
        "disposition"
      ],
      "title": "LegacyInventoryRule",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": 1,
      "enum": [
        1,
        2
      ],
      "title": "Schema Version",
      "type": "integer"
    },
    "source_repository": {
      "minLength": 1,
      "title": "Source Repository",
      "type": "string"
    },
    "source_commit": {
      "pattern": "^[a-f0-9]{40}$",
      "title": "Source Commit",
      "type": "string"
    },
    "rules": {
      "items": {
        "$ref": "#/$defs/LegacyInventoryRule"
      },
      "minItems": 1,
      "title": "Rules",
      "type": "array"
    }
  },
  "required": [
    "source_repository",
    "source_commit",
    "rules"
  ],
  "title": "Career OS Legacy Inventory Rules",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-os.dev/schemas/legacy-inventory-rules.schema.json"
}
