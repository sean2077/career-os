{
  "$defs": {
    "ObsidianConfig": {
      "additionalProperties": false,
      "description": "Obsidian integration version requirements.",
      "properties": {
        "minimum_version": {
          "default": "1.12.7",
          "description": "Minimum supported Obsidian version.",
          "title": "Minimum Version",
          "type": "string"
        },
        "quickadd_version": {
          "default": "2.12.3",
          "description": "QuickAdd version expected by the optional Obsidian integration.",
          "title": "Quickadd Version",
          "type": "string"
        }
      },
      "title": "ObsidianConfig",
      "type": "object"
    },
    "OpenCLIConfig": {
      "additionalProperties": false,
      "description": "Allowlisted OpenCLI research integration settings.",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Whether read-only OpenCLI research commands are enabled.",
          "title": "Enabled",
          "type": "boolean"
        },
        "profile": {
          "default": "career-research",
          "description": "Portable OpenCLI profile alias used for research commands.",
          "title": "Profile",
          "type": "string"
        },
        "timeout_seconds": {
          "default": 60,
          "description": "Maximum execution time for one OpenCLI command, in seconds.",
          "maximum": 300,
          "minimum": 1,
          "title": "Timeout Seconds",
          "type": "integer"
        },
        "capture_subdir": {
          "default": "research/opencli",
          "description": "Portable POSIX subdirectory under the fixed local runtime root for captured research.",
          "title": "Capture Subdir",
          "type": "string"
        },
        "sources": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": "Allowlist mapping each OpenCLI site name to its permitted read commands.",
          "title": "Sources",
          "type": "object"
        }
      },
      "title": "OpenCLIConfig",
      "type": "object"
    },
    "ResearchConfig": {
      "additionalProperties": false,
      "description": "Optional external research integration settings.",
      "properties": {
        "opencli": {
          "$ref": "#/$defs/OpenCLIConfig",
          "description": "Read-only OpenCLI research integration."
        }
      },
      "title": "ResearchConfig",
      "type": "object"
    },
    "ResumeConfig": {
      "additionalProperties": false,
      "description": "Resume build configuration.",
      "properties": {
        "engine": {
          "default": "xelatex",
          "description": "TeX engine used to build Career OS resumes.",
          "title": "Engine",
          "type": "string"
        },
        "fonts": {
          "$ref": "#/$defs/ResumeFontsConfig",
          "description": "Project-wide local resume font overrides."
        }
      },
      "title": "ResumeConfig",
      "type": "object"
    },
    "ResumeFontRoles": {
