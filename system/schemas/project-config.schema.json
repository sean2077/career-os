      "title": "ResumeFontRoles",
      "type": "object"
    },
    "ResumeFontsConfig": {
      "additionalProperties": false,
      "description": "Project-wide local font directory and role overrides.",
      "properties": {
        "directory": {
          "default": ".career-os/fonts",
          "description": "Portable project-relative directory containing local resume fonts.",
          "title": "Directory",
          "type": "string"
        },
        "roles": {
          "$ref": "#/$defs/ResumeFontRoles",
          "description": "Optional fixed resume font role overrides."
        }
      },
      "title": "ResumeFontsConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Career OS project configuration stored in career-os.toml.",
  "properties": {
    "schema_version": {
      "const": 2,
      "description": "Version of the Career OS project configuration schema.",
      "title": "Schema Version",
      "type": "integer"
    },
    "system_version": {
      "description": "Career OS system version expected by this project.",
      "title": "System Version",
      "type": "string"
    },
    "development_topology": {
      "default": "standalone-framework",
      "description": "Repository topology: a public standalone framework, an integrated private workbench, or a split downstream.",
      "enum": [
        "standalone-framework",
        "integrated-workbench",
        "split-downstream"
      ],
      "title": "Development Topology",
      "type": "string"
    },
    "build_root": {
      "default": "build",
      "description": "Path for generated build artifacts.",
      "title": "Build Root",
      "type": "string"
    },
    "preferred_language": {
      "default": "en",
      "description": "Preferred language code for Career OS content and output.",
      "title": "Preferred Language",
      "type": "string"
    },
    "obsidian": {
      "$ref": "#/$defs/ObsidianConfig",
      "description": "Obsidian integration settings."
    },
    "resume": {
      "$ref": "#/$defs/ResumeConfig",
      "description": "Resume build settings."
    },
    "research": {
      "$ref": "#/$defs/ResearchConfig",
      "description": "Optional external research integrations."
    }
  },
  "required": [
    "schema_version",
    "system_version"
  ],
  "title": "Career OS Project Configuration",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-os.dev/schemas/project-config.schema.json"
}
