{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-os.dev/schemas/vault-install.schema.json",
  "title": "Career OS Vault Install State",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "attach_plan_id", "system_version", "vault_root", "data_root", "repository_mode", "with_quickadd", "roots", "changes", "warnings"],
  "properties": {
    "schema_version": {"const": 1},
    "attach_plan_id": {"type": "string", "format": "uuid"},
    "system_version": {"type": "string"},
    "vault_root": {"type": "string"},
    "vault_mount": {"type": ["string", "null"]},
    "data_root": {"type": "string"},
    "repository_mode": {"type": "string"},
    "with_quickadd": {"type": "boolean"},
    "roots": {"type": "object", "additionalProperties": {"type": "string"}},
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["root", "path", "operation_index", "original_sha256", "installed_sha256"],
        "properties": {
          "root": {"enum": ["project", "vault", "data", "runtime", "host_repo"]},
          "path": {"type": "string"},
          "operation_index": {"type": "integer", "minimum": 0},
          "original_sha256": {"type": ["string", "null"]},
          "installed_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}}
  }
}
