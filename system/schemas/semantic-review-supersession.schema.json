{
  "$id": "https://career-os.dev/schemas/semantic-review-supersession.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Bind an immutable migration review to the correction that replaced its targets.",
  "properties": {
    "completion_path": {
      "title": "Completion Path",
      "type": "string"
    },
    "completion_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Completion Sha256",
      "type": "string"
    },
    "control_type": {
      "const": "semantic-review-supersession",
      "default": "semantic-review-supersession",
      "title": "Control Type",
      "type": "string"
    },
    "correction_manifest_id": {
      "format": "uuid4",
      "title": "Correction Manifest Id",
      "type": "string"
    },
    "correction_manifest_path": {
      "title": "Correction Manifest Path",
      "type": "string"
    },
    "correction_provenance_path": {
      "title": "Correction Provenance Path",
      "type": "string"
    },
    "reason": {
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "review_path": {
      "title": "Review Path",
      "type": "string"
    },
    "review_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Review Sha256",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "supersedes_manifest_id": {
      "format": "uuid4",
      "title": "Supersedes Manifest Id",
      "type": "string"
    }
  },
  "required": [
    "review_path",
    "review_sha256",
    "completion_path",
    "completion_sha256",
    "correction_manifest_id",
    "supersedes_manifest_id",
    "correction_manifest_path",
    "correction_provenance_path",
    "reason"
  ],
  "title": "Career OS Semantic Review Supersession",
  "type": "object"
}
