{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-os.dev/schemas/install-state.schema.json",
  "title": "Career OS Install State",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "project_root", "vault_root", "data_root", "system_version", "languages"],
  "properties": {
    "schema_version": {"const": 1},
    "mode": {"enum": ["standalone", "embedded"]},
    "project_root": {"type": "string"},
    "vault_root": {"type": "string"},
    "vault_mount": {"type": ["string", "null"]},
    "data_root": {"type": "string"},
    "system_version": {"type": "string"},
    "languages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
  }
}
