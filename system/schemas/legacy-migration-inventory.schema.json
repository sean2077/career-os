{
  "$defs": {
    "LegacyMigrationInventoryEntry": {
      "additionalProperties": false,
      "properties": {
        "asset_type": {"enum": ["record", "attachment", "resume", "view", "skill", "tool", "documentation", "other"], "title": "Asset Type", "type": "string"},
        "disposition": {"enum": ["migrate-exact", "migrate-transform", "replace-by-public", "retain-archive-only", "upstream-gap", "retire"], "title": "Disposition", "type": "string"},
        "hash_basis": {"enum": ["worktree-file", "git-symlink-payload", "gitlink-oid"], "title": "Hash Basis", "type": "string"},
        "note": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Note"},
        "replacement": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Replacement"},
        "rule_id": {"pattern": "^[a-z0-9][a-z0-9._-]*$", "title": "Rule Id", "type": "string"},
        "source_git_mode": {"pattern": "^[0-7]{6}$", "title": "Source Git Mode", "type": "string"},
        "source_git_oid": {"pattern": "^[a-f0-9]{40}$", "title": "Source Git Oid", "type": "string"},
        "source_path": {"title": "Source Path", "type": "string"},
        "source_sha256": {"pattern": "^[a-f0-9]{64}$", "title": "Source Sha256", "type": "string"},
        "source_size": {"minimum": 0, "title": "Source Size", "type": "integer"}
      },
      "required": ["source_path", "source_sha256", "source_size", "source_git_mode", "source_git_oid", "hash_basis", "asset_type", "disposition", "rule_id"],
      "title": "LegacyMigrationInventoryEntry",
      "type": "object"
    }
  },
  "$id": "https://career-os.dev/schemas/legacy-migration-inventory.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "entries": {"items": {"$ref": "#/$defs/LegacyMigrationInventoryEntry"}, "minItems": 1, "title": "Entries", "type": "array"},
    "rules_sha256": {"pattern": "^[a-f0-9]{64}$", "title": "Rules Sha256", "type": "string"},
    "schema_version": {"const": 1, "default": 1, "title": "Schema Version", "type": "integer"},
    "source_commit": {"pattern": "^[a-f0-9]{40}$", "title": "Source Commit", "type": "string"},
    "source_repository": {"minLength": 1, "title": "Source Repository", "type": "string"}
  },
  "required": ["source_repository", "source_commit", "rules_sha256", "entries"],
  "title": "Career OS Legacy Migration Inventory",
  "type": "object"
}
